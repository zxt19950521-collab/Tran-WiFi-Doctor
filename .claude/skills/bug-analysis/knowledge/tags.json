      "id": "TAG-085",
      "name": "Class-2 frame",
      "category": "disconnect",
      "description": "AP因收不到上行帧认为STA未关联而下发deauth",
      "patterns": ["reason=6", "Class-2 frame from nonassociated STA"],
      "auto_extract": true
    },
    {
      "id": "TAG-086",
      "name": "DTIM配置失败",
      "category": "performance",
      "description": "WiFi省电模式DTIM配置失败",
      "patterns": ["setDtimMultiplier failed"],
      "auto_extract": true
    },
    {
      "id": "TAG-087",
      "name": "吞吐突发-空闲波动",
      "category": "performance",
      "description": "吞吐量从数百Mbps瞬间跌到接近0，呈突发-空闲模式",
      "patterns": ["kalPerMonUpdate"],
      "auto_extract": true
    },
    {
      "id": "TAG-088",
      "name": "WifiNetworkQuality高Ping时延",
      "category": "disconnect",
      "description": "传音WifiNetworkQuality检测到高Ping时延后触发网络质量策略",
      "patterns": ["isHighPingDelay : true", "WifiNetworkQuality: start scan"],
      "auto_extract": true
    },
    {
      "id": "TAG-089",
      "name": "wlan0 tear down",
      "category": "disconnect",
      "description": "框架层主动拆除wlan0 STA接口导致WiFi断连",
      "patterns": ["Successfully torn down Iface.*wlan0", "Type=STA_CONNECTIVITY"],
      "auto_extract": true
    },
    {
      "id": "TAG-090",
      "name": "WificondScannerImpl扫描失败",
      "category": "scan-failure",
      "description": "WificondScannerImpl启动扫描失败，常见于status=-9",
      "patterns": ["WificondScannerImpl: Failed to start scan", "status: -9"],
      "auto_extract": true
    },
    {
      "id": "TAG-091",
      "name": "应用层网络误报",
      "category": "disconnect",
      "description": "第三方App报网络不可用但系统WiFi仍连接且Ping/Probe正常，kernel PER截图时刻通常≤10%",
      "patterns": ["SBE.*abnormal implementation", "libshp_weaknetwork"],
      "auto_extract": true
    },
    {
      "id": "TAG-092",
      "name": "截图时刻PER正常",
      "category": "performance",
      "description": "wlanLinkQualityMonitor在问题截图时刻PER极低，排除空口高PER导致应用报错",
      "patterns": ["wlanLinkQualityMonitor.*PER\\([0-9]\\)", "wlanLinkQualityMonitor.*PER\\(1[0-9]\\)"],
      "auto_extract": false
    }
  ],
